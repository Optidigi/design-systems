    {
      "name": "base",
      "type": "registry:base",
      "title": "SIAB Base",
      "description": "Project bootstrap \u2014 Tailwind v4 base layer, tw-animate-css, lucide icons, SIAB theme tokens. Consumed by `shadcn init --preset` for new projects.",
      "registryDependencies": [
        "@siab/theme",
        "@siab/utils"
      ],
      "dependencies": [
        "tailwindcss",
        "tw-animate-css",
        "class-variance-authority",
        "clsx",
        "tailwind-merge",
        "lucide-react"
      ],
      "config": {
        "style": "new-york",
        "iconLibrary": "lucide",
        "tailwind": {
          "baseColor": "neutral"
        }
      },
      "css": {
        "@import \"tailwindcss\"": {},
        "@import \"tw-animate-css\"": {},
        "@custom-variant dark (&:is(.dark *))": {},
        "@layer base": {
          "*": {
            "@apply border-border outline-ring/50": {}
          },
          "body": {
            "@apply bg-background text-foreground": {}
          }
        }
      }
    },
